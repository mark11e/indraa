local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

-- Start as early as possible
repeat task.wait() until game:IsLoaded()

local LocalPlayer = Players.LocalPlayer

-- Initialize map and pet data FIRST (no character dependency)
local Map = Workspace:WaitForChild("Map", 30)  -- generous timeout
local WildPetSpawns = Map:WaitForChild("WildPetSpawns")
local WildPetRef = Map:WaitForChild("WildPetRef")

-- Price thresholds and wanted pets
local MaxPrice = {
    Bear = 5000000,
    DragonFly = 9000000,
    Unicorn = 12000000,
    Raccoon = 15000000,
}

local WantedPets = {
    Unicorn = true,
    DragonFly = true,
    Raccoon = true,
    Bear = true,
}

local PurchasedPets = {}

local function parsePrice(text)
    return tonumber((text:gsub("[^%d]", ""))) or math.huge
end

-- Track current target
local currentTarget = nil

local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHRPAndHumanoid()
    local character = getCharacter()
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    local humanoid = character:WaitForChild("Humanoid", 5)
    return character, hrp, humanoid
end

-- Main loop
while task.wait(0.3) do  -- slightly faster scan
    local character, hrp, humanoid = getHRPAndHumanoid()
    
    if not hrp or not humanoid then
        currentTarget = nil
        continue
    end

    -- === HANDLE CURRENT TARGET ===
    if currentTarget then
        local distance = (hrp.Position - currentTarget.refPart.Position).Magnitude
        print(string.format("Walking to %s - distance: %.1f", currentTarget.petType, distance))

        if distance < 8 then
            -- Buy it
            local prompt = currentTarget.prompt
            if prompt.HoldDuration > 0 then
                fireproximityprompt(prompt, prompt.HoldDuration)
            else
                fireproximityprompt(prompt)
            end

            PurchasedPets[currentTarget.uuid] = true
            print(string.format("Bought %s (UUID: %s)", currentTarget.petType, currentTarget.uuid))
            
            currentTarget = nil
            humanoid:MoveTo(hrp.Position) -- stop moving
        else
            -- Keep walking
            humanoid:MoveTo(currentTarget.refPart.Position + Vector3.new(0, 3, 0))
        end
        continue
    end

    -- === SCAN FOR NEW PETS ===
    for _, model in ipairs(WildPetSpawns:GetChildren()) do
        local petType = model.Name:match("WildPet_(.-)_WildPet_")
        if not petType or not WantedPets[petType] then
            continue
        end

        local uuid = model.Name:match("WildPet_.-_WildPet_(.+)$")
        if not uuid or PurchasedPets[uuid] then
            continue
        end

        local refPart = WildPetRef:FindFirstChild("WildPet_" .. uuid)
        if not refPart then continue end

        local priceLabel = model:FindFirstChild("RootPart", true)?.PetCostTimer?.TextLabel
        if not priceLabel then continue end

        local currentPrice = parsePrice(priceLabel.Text)
        if currentPrice > MaxPrice[petType] then
            continue
        end

        local prompt = model:FindFirstChild("BuyPrompt", true)
        if not prompt then continue end

        local distance = (hrp.Position - refPart.Position).Magnitude

        if distance < 8 then
            -- Already close
            if prompt.HoldDuration > 0 then
                fireproximityprompt(prompt, prompt.HoldDuration)
            else
                fireproximityprompt(prompt)
            end
            PurchasedPets[uuid] = true
            print(string.format("Bought %s (UUID: %s) for %s (already nearby)", petType, uuid, priceLabel.Text))
        else
            -- Start walking to it
            print(string.format("Walking to %s (UUID: %s) - distance: %.1f", petType, uuid, distance))
            humanoid:MoveTo(refPart.Position + Vector3.new(0, 3, 0))
            
            currentTarget = {
                refPart = refPart,
                prompt = prompt,
                petType = petType,
                uuid = uuid,
            }
        end

        break  -- only target one at a time
    end
end
